# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/reflex?retryWrites=true&w=majority

# Random long string used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Built-in admin credentials (for initial dashboard access)
ADMIN_USER=admin
ADMIN_PASS=change-this-in-production

# Local dev port (ignored by Vercel)
PORT=8080
